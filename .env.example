# ─── caboose-mcp environment variables ───────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit secrets.

# ── Core ──────────────────────────────────────────────────────────────────────
# Base directory for all caboose-mcp data (notes, secrets, sessions, logs).
# Defaults to ~/.claude if unset.
CLAUDE_DIR=

# ── HTTP transport ────────────────────────────────────────────────────────────
# Bearer token required on all /mcp requests when running --serve mode.
# Leave blank to disable auth (local only).
MCP_AUTH_TOKEN=

# ── AWS / Bedrock ─────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Secrets (GPG) ─────────────────────────────────────────────────────────────
# GPG key ID for secret_* tools. Find with: gpg --list-keys
GPG_KEY_ID=

# ── GitHub ────────────────────────────────────────────────────────────────────
# Auto-resolved from `gh auth token` if blank.
GITHUB_TOKEN=

# ── Slack ─────────────────────────────────────────────────────────────────────
# Bot OAuth token from api.slack.com/apps (xoxb-...)
SLACK_TOKEN=

# ── Discord ───────────────────────────────────────────────────────────────────
# Bot token from discord.com/developers/applications
DISCORD_TOKEN=

# ── n8n ───────────────────────────────────────────────────────────────────────
# URL of the n8n webhook that receives caboose-mcp events.
# When running via docker compose this is pre-wired; only set if running standalone.
N8N_WEBHOOK_URL=http://localhost:5678/webhook/caboose-events
N8N_API_KEY=
# n8n public URL (only needed if exposing n8n externally)
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_PUBLIC_URL=http://localhost:5678
# Basic auth for n8n (recommended if exposed publicly)
N8N_BASIC_AUTH_ACTIVE=false
N8N_BASIC_AUTH_USER=
N8N_BASIC_AUTH_PASSWORD=

# ── Databases ─────────────────────────────────────────────────────────────────
POSTGRES_URL=
MONGO_URL=

# ── 3D Printing (Bambu A1) ────────────────────────────────────────────────────
BAMBU_IP=
BAMBU_ACCESS_CODE=
BAMBU_SERIAL=
BAMBU_BED_TEMP=55
BAMBU_NOZZLE_TEMP=220

# ── Greptile ──────────────────────────────────────────────────────────────────
GREPTILE_API_KEY=
GREPTILE_REPO=github/caboose-mcp/caboose-mcp

# ── Cloud Sync ────────────────────────────────────────────────────────────────
CLOUDSYNC_S3_BUCKET=
