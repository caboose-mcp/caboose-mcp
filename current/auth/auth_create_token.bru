  token: {{authToken}}
}

body:json {
  {
    "jsonrpc": "2.0",
    "id": 9,
    "method": "tools/call",
    "params": {
      "name": "auth_create_token",
      "arguments": {}
    }
  }
}

docs {
  Create a JWT token with specific tool access. Returns a magic link valid for 15 minutes that can be exchanged for a JWT.
}
