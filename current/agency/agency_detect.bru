meta {
  name: agency_detect
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/mcp
  body: json
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

body:json {
  {
    "jsonrpc": "2.0",
    "id": 1,
    "method": "tools/call",
    "params": {
      "name": "agency_detect",
      "arguments": {}
    }
  }
}

docs {
  Detect the best-matching agent persona for a given message. Returns the matched agent name, its confidence score, and the score threshold used to accept a match.
}
