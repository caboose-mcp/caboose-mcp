meta {
  name: postgres_query
  type: http
  seq: 83
}

post {
  url: {{baseUrl}}/mcp
  body: json
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

body:json {
  {
    "jsonrpc": "2.0",
    "id": 83,
    "method": "tools/call",
    "params": {
      "name": "postgres_query",
      "arguments": {}
    }
  }
}

docs {
  Execute a SQL query against a PostgreSQL database.
}
