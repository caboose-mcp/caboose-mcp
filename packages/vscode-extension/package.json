{
  "name": "vscode-caboose-mcp",
  "displayName": "Caboose MCP",
  "description": "VS Code sidebar and status bar for the caboose-mcp personal AI toolserver",
  "version": "0.1.0",
  "publisher": "caboose",
  "repository": {
    "type": "git",
    "url": "https://github.com/caboose-mcp/vscode-extension"
  },
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Caboose MCP",
      "properties": {
        "cabooseMcp.transport": {
          "type": "string",
          "enum": ["http", "stdio"],
          "default": "http",
          "description": "Transport used to connect to caboose-mcp. Use 'http' (default) for a running server, or 'stdio' to spawn the binary directly."
        },
        "cabooseMcp.host": {
          "type": "string",
          "default": "localhost",
          "description": "Hostname of the caboose-mcp HTTP server (http transport only)."
        },
        "cabooseMcp.port": {
          "type": "number",
          "default": 3000,
          "description": "Port of the caboose-mcp HTTP server (http transport only)."
        },
        "cabooseMcp.binaryPath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the caboose-mcp binary (e.g. /home/caboose/dev/caboose-mcp/caboose-mcp)."
        },
        "cabooseMcp.env": {
          "type": "object",
          "default": {},
          "description": "Environment variables passed to the caboose-mcp process (e.g. SLACK_TOKEN, DISCORD_TOKEN, GPG_KEY_ID).",
          "additionalProperties": { "type": "string" }
        },
        "cabooseMcp.enabledTools": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["*"],
          "description": "Tools to show in the sidebar. Use [\"*\"] for all, or list specific names like [\"focus_start\", \"note_add\"]."
        },
        "cabooseMcp.autoConnect": {
          "type": "boolean",
          "default": true,
          "description": "Automatically connect to caboose-mcp on VS Code startup if binaryPath is set."
        },
        "cabooseMcp.statusBar.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show a status bar item for caboose-mcp."
        },
        "cabooseMcp.statusBar.tool": {
          "type": "string",
          "default": "focus_status",
          "description": "Tool to poll for status bar display. Leave empty to show only connection status."
        },
        "cabooseMcp.statusBar.intervalSeconds": {
          "type": "number",
          "default": 30,
          "minimum": 5,
          "description": "How often (in seconds) to poll the status bar tool."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "caboose-mcp",
          "title": "Caboose MCP",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "caboose-mcp": [
        {
          "id": "cabooseMcp.tools",
          "name": "Tools",
          "contextualTitle": "Caboose MCP Tools"
        }
      ]
    },
    "commands": [
      {
        "command": "cabooseMcp.connect",
        "title": "Connect",
        "category": "Caboose MCP",
        "icon": "$(plug)"
      },
      {
        "command": "cabooseMcp.disconnect",
        "title": "Disconnect",
        "category": "Caboose MCP",
        "icon": "$(debug-disconnect)"
      },
      {
        "command": "cabooseMcp.refresh",
        "title": "Refresh Tools",
        "category": "Caboose MCP",
        "icon": "$(refresh)"
      },
      {
        "command": "cabooseMcp.runTool",
        "title": "Run Tool",
        "category": "Caboose MCP",
        "icon": "$(run)"
      },
      {
        "command": "cabooseMcp.openSettings",
        "title": "Open Settings",
        "category": "Caboose MCP",
        "icon": "$(gear)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "cabooseMcp.refresh",
          "when": "view == cabooseMcp.tools",
          "group": "navigation"
        },
        {
          "command": "cabooseMcp.connect",
          "when": "view == cabooseMcp.tools && !cabooseMcp.connected",
          "group": "navigation"
        },
        {
          "command": "cabooseMcp.disconnect",
          "when": "view == cabooseMcp.tools && cabooseMcp.connected",
          "group": "navigation"
        },
        {
          "command": "cabooseMcp.openSettings",
          "when": "view == cabooseMcp.tools",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "cabooseMcp.runTool",
          "when": "view == cabooseMcp.tools && viewItem == tool",
          "group": "inline"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "typescript": "^5.3.0"
  }
}
