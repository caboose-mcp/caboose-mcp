# caboose-mcp environment variables
# Export these in your shell, set them in your service manager, or load from .env

# Claude self-learning tools
# Default: ~/.claude
CLAUDE_DIR=~/.claude

# GPG key ID for encrypted secrets (leave empty to disable secrets tools)
# Find yours: gpg --list-keys
GPG_KEY_ID=

# Slack Bot OAuth token (xoxb-...)
SLACK_TOKEN=

# Discord bot token
DISCORD_TOKEN=

# Bambu A1 printer (LAN mode)
BAMBU_IP=
BAMBU_ACCESS_CODE=        # 8-char code shown on printer touchscreen
BAMBU_SERIAL=             # printer serial number
BAMBU_BED_TEMP=55         # default bed temperature °C
BAMBU_NOZZLE_TEMP=220     # default nozzle temperature °C

# Greptile code search API
GREPTILE_API_KEY=
GREPTILE_REPO=github/caboose/caboose-mcp

# Database connections (optional; can be overridden per-call)
POSTGRES_URL=postgres://user:pass@localhost:5432/dbname
MONGO_URL=mongodb://localhost:27017

# GitHub token for cloud sync Gist backend and source_check
# Auto-resolved from `gh auth token` if not set here
GITHUB_TOKEN=

# Cloud sync — S3 backend only (Gist uses GITHUB_TOKEN above)
CLOUDSYNC_S3_BUCKET=   # e.g. my-config-bucket

# n8n integration — push events to n8n workflows
N8N_WEBHOOK_URL=       # n8n Webhook node URL (e.g. http://localhost:5678/webhook/caboose-events)
N8N_API_KEY=           # n8n API key (optional — sent as X-N8N-API-KEY header)
