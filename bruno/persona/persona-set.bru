meta {
  name: persona-set
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/mcp
  body: json
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

body:json {
  {
    "jsonrpc": "2.0",
    "id": 2,
    "method": "tools/call",
    "params": {
      "name": "agent_persona",
      "arguments": {
        ""action"": "set"
        ""name"": "Caboose"
        ""tone"": "playful"
        ""verbosity"": "normal"
      }
    }
  }
}
