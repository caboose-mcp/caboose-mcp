meta {
  name: calendar-create
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/mcp
  body: json
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

body:json {
  {
    "jsonrpc": "2.0",
    "id": 3,
    "method": "tools/call",
    "params": {
      "name": "calendar_create",
      "arguments": {
        ""title"": "Team standup"
        ""start"": "2026-03-20 09:00"
        ""end"": "2026-03-20 09:30"
      }
    }
  }
}
