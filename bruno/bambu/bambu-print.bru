meta {
  name: bambu-print
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/mcp
  body: json
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

body:json {
  {
    "jsonrpc": "2.0",
    "id": 3,
    "method": "tools/call",
    "params": {
      "name": "bambu_print",
      "arguments": {
        ""file_path"": "/path/to/model.3mf"
      }
    }
  }
}
