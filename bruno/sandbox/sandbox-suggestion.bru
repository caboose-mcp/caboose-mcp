meta {
  name: sandbox-suggestion
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/mcp
  body: json
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

body:json {
  {
    "jsonrpc": "2.0",
    "id": 5,
    "method": "tools/call",
    "params": {
      "name": "sandbox_suggestion",
      "arguments": {
        ""id"": "<suggestion-id>"
      }
    }
  }
}
