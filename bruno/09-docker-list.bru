meta {
  name: Docker List Containers
  type: http
  seq: 9
}

post {
  url: {{baseUrl}}/mcp
  body: json
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

body:json {
  {
    "jsonrpc": "2.0",
    "id": 9,
    "method": "tools/call",
    "params": {
      "name": "docker_list_containers",
      "arguments": {
        "all": false
      }
    }
  }
}
