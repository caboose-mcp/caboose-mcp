meta {
  name: secret-get
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/mcp
  body: json
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

body:json {
  {
    "jsonrpc": "2.0",
    "id": 2,
    "method": "tools/call",
    "params": {
      "name": "secret_get",
      "arguments": {
        ""name"": "my-secret"
      }
    }
  }
}
