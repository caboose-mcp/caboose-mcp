meta {
  name: secret-set
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/mcp
  body: json
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

body:json {
  {
    "jsonrpc": "2.0",
    "id": 3,
    "method": "tools/call",
    "params": {
      "name": "secret_set",
      "arguments": {
        ""name"": "my-secret"
        ""value"": "super-secret-value"
      }
    }
  }
}
