meta {
  name: mongodb-query
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/mcp
  body: json
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

body:json {
  {
    "jsonrpc": "2.0",
    "id": 4,
    "method": "tools/call",
    "params": {
      "name": "mongodb_query",
      "arguments": {
        ""database"": "mydb"
        ""collection"": "users"
        ""limit"": 10
      }
    }
  }
}
