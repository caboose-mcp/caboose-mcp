meta {
  name: postgres-query
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/mcp
  body: json
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

body:json {
  {
    "jsonrpc": "2.0",
    "id": 2,
    "method": "tools/call",
    "params": {
      "name": "postgres_query",
      "arguments": {
        ""query"": "SELECT version()"
      }
    }
  }
}
