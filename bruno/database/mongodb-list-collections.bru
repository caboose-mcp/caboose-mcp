meta {
  name: mongodb-list-collections
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/mcp
  body: json
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

body:json {
  {
    "jsonrpc": "2.0",
    "id": 3,
    "method": "tools/call",
    "params": {
      "name": "mongodb_list_collections",
      "arguments": {
        ""database"": "mydb"
      }
    }
  }
}
