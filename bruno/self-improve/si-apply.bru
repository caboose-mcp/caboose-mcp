meta {
  name: si-apply
  type: http
  seq: 6
}

post {
  url: {{baseUrl}}/mcp
  body: json
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

body:json {
  {
    "jsonrpc": "2.0",
    "id": 6,
    "method": "tools/call",
    "params": {
      "name": "si_apply",
      "arguments": {
        ""id"": "<suggestion-id>"
      }
    }
  }
}
