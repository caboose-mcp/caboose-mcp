meta {
  name: discord-post-message
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/mcp
  body: json
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

body:json {
  {
    "jsonrpc": "2.0",
    "id": 3,
    "method": "tools/call",
    "params": {
      "name": "discord_post_message",
      "arguments": {
        ""channel_id"": "<channel-id>"
        ""content"": "Hello from Bruno!"
      }
    }
  }
}
