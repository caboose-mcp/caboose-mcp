meta {
  name: discord-read-messages
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/mcp
  body: json
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

body:json {
  {
    "jsonrpc": "2.0",
    "id": 2,
    "method": "tools/call",
    "params": {
      "name": "discord_read_messages",
      "arguments": {
        ""channel_id"": "<channel-id>"
        ""limit"": 10
      }
    }
  }
}
