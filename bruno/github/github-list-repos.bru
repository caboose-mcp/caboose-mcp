meta {
  name: github-list-repos
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/mcp
  body: json
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

body:json {
  {
    "jsonrpc": "2.0",
    "id": 1,
    "method": "tools/call",
    "params": {
      "name": "github_list_repos",
      "arguments": {
        ""owner"": "caboose-mcp"
        ""limit"": 20
      }
    }
  }
}
