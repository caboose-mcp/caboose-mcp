meta {
  name: Execute Command
  type: http
  seq: 8
}

post {
  url: {{baseUrl}}/mcp
  body: json
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

body:json {
  {
    "jsonrpc": "2.0",
    "id": 8,
    "method": "tools/call",
    "params": {
      "name": "execute_command",
      "arguments": {
        "command": "uptime"
      }
    }
  }
}
