meta {
  name: docker-inspect
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/mcp
  body: json
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

body:json {
  {
    "jsonrpc": "2.0",
    "id": 4,
    "method": "tools/call",
    "params": {
      "name": "docker_inspect",
      "arguments": {
        ""container"": "<container-name>"
      }
    }
  }
}
