meta {
  name: docker-logs
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/mcp
  body: json
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

body:json {
  {
    "jsonrpc": "2.0",
    "id": 3,
    "method": "tools/call",
    "params": {
      "name": "docker_logs",
      "arguments": {
        ""container"": "<container-name>"
        ""tail"": 50
      }
    }
  }
}
