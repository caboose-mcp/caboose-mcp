  token: {{authToken}}
}

body:json {
  {
    "jsonrpc": "2.0",
    "id": 1,
    "method": "tools/call",
    "params": {
      "name": "docker_list_containers",
      "arguments": {
        ""all"": false
      }
    }
  }
}
