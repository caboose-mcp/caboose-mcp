meta {
  name: learn-submit
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/mcp
  body: json
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

body:json {
  {
    "jsonrpc": "2.0",
    "id": 4,
    "method": "tools/call",
    "params": {
      "name": "learn_submit",
      "arguments": {
        ""session_id"": "<session-id>"
        ""prompt"": "<the question>"
        ""answer"": "my answer"
        ""correct"": true
      }
    }
  }
}
