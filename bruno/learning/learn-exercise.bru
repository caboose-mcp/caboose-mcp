meta {
  name: learn-exercise
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/mcp
  body: json
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

body:json {
  {
    "jsonrpc": "2.0",
    "id": 3,
    "method": "tools/call",
    "params": {
      "name": "learn_exercise",
      "arguments": {
        ""session_id"": "<session-id-from-learn-start>"
      }
    }
  }
}
