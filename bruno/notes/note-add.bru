meta {
  name: note-add
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/mcp
  body: json
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

body:json {
  {
    "jsonrpc": "2.0",
    "id": 1,
    "method": "tools/call",
    "params": {
      "name": "note_add",
      "arguments": {
        ""text"": "Test note from Bruno"
        ""tag"": "idea"
      }
    }
  }
}
