meta {
  name: focus-start
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/mcp
  body: json
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

body:json {
  {
    "jsonrpc": "2.0",
    "id": 1,
    "method": "tools/call",
    "params": {
      "name": "focus_start",
      "arguments": {
        ""goal"": "Deep work on fafb"
        ""duration_minutes"": 25
      }
    }
  }
}
