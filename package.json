{
  "name": "fafb",
  "private": true,
  "description": "fafb monorepo — MCP server",
  "scripts": {
    "build": "pnpm server:build",
    "server:build": "cd packages/server && /usr/local/go/bin/go build -o fafb .",
    "docker:build": "docker build -f docker/Dockerfile -t fafb-server .",
    "docker:up": "docker compose -f docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f docker/docker-compose.yml down",
    "docker:logs": "docker compose -f docker/docker-compose.yml logs -f"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
