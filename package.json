{
  "name": "fafb",
  "private": true,
  "description": "fafb monorepo — MCP server + VS Code extension",
  "scripts": {
    "build": "pnpm --filter vscode-fafb compile && pnpm server:build",
    "server:build": "cd packages/server && /usr/local/go/bin/go build -o fafb .",
    "extension:compile": "pnpm --filter vscode-fafb compile",
    "extension:watch": "pnpm --filter vscode-fafb watch",
    "extension:package": "pnpm --filter vscode-fafb package",
    "docker:build": "docker build -f docker/Dockerfile -t fafb-server .",
    "docker:up": "docker compose -f docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f docker/docker-compose.yml down",
    "docker:logs": "docker compose -f docker/docker-compose.yml logs -f",
    "lint": "pnpm --filter vscode-fafb lint"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
